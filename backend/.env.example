# 销售管理系统后端环境变量配置
# 复制为 .env 后按需修改，未设置的变量使用下方默认值

# ─── 基础 ──────────────────────────────────────────────────
# 运行环境：development / production
APP_ENV=development
BACKEND_PORT=8000

# ─── 数据库 ────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sales_management
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sales_management
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# ─── JWT 认证 ──────────────────────────────────────────────
# 生产环境必须设置为安全随机字符串
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
# 允许的前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173

# ─── 日志 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text

# ─── 文件上传 ──────────────────────────────────────────────
UPLOAD_STORAGE_TYPE=local
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
MAX_IMAGE_SIZE_MB=5
MAX_CSV_IMPORT_SIZE_MB=10

# ─── 业务 ──────────────────────────────────────────────────
INVENTORY_WARNING_THRESHOLD=10

# ─── 速率限制 ──────────────────────────────────────────────
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60

# ─── 可观测性 ──────────────────────────────────────────────
SLOW_REQUEST_THRESHOLD_MS=1000
