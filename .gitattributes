# 自动检测文本文件并规范化行尾
* text=auto eol=lf

# 脚本文件强制 LF
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.conf text eol=lf

# Windows 脚本保持 CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.sqlite binary
