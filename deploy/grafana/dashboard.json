{
  "annotations": { "list": [] },
  "description": "销售管理系统业务运营仪表盘",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "订单创建速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(business_order_created_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "订单确认 / 取消速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(business_order_confirmed_total[5m])",
          "legendFormat": "确认",
          "refId": "A"
        },
        {
          "expr": "rate(business_order_cancelled_total[5m])",
          "legendFormat": "取消",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "收款登记速率（按方式）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(business_payment_registered_total[5m])",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "收款冲正速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(business_payment_reversed_total[5m])",
          "legendFormat": "冲正",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "title": "库存不足事件",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "increase(business_inventory_stockout_total[1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "低库存商品数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "business_low_stock_products",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "登录成功/失败",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(business_login_attempts_total{result=\"success\"}[5m])",
          "legendFormat": "成功",
          "refId": "A"
        },
        {
          "expr": "rate(business_login_attempts_total{result=\"failed\"}[5m])",
          "legendFormat": "失败",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min"
        }
      }
    },
    {
      "title": "HTTP 请求速率（按状态码）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "API 延迟 P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "订单取消率",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(business_order_cancelled_total[1h]) / (rate(business_order_confirmed_total[1h]) + rate(business_order_cancelled_total[1h]) + 0.001) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "收款冲正率",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "targets": [
        {
          "expr": "rate(business_payment_reversed_total[1h]) / (rate(business_payment_registered_total[1h]) + 0.001) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sales-management", "business"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "销售管理系统 - 业务运营",
  "uid": "sales-mgmt-business",
  "version": 1
}
