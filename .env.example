# 应用环境
APP_ENV=development

# 后端端口
BACKEND_PORT=8000

# 前端端口
FRONTEND_PORT=5173

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sales_management

# 数据库连接（Docker 内使用主机名 postgres，本地开发使用 localhost）
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sales_management
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sales_management

# JWT 配置
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的前端地址
CORS_ORIGINS=http://localhost:5173

# 日志级别
LOG_LEVEL=INFO

# 日志格式：text（开发）或 json（生产）
LOG_FORMAT=text

# 文件上传配置
UPLOAD_STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
MAX_IMAGE_SIZE_MB=5
MAX_CSV_IMPORT_SIZE_MB=10

# 库存预警阈值
INVENTORY_WARNING_THRESHOLD=10

# API 速率限制（每窗口最大请求数 / 窗口秒数）
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60

# 慢请求阈值（毫秒，超过此值的请求日志升级为 WARNING）
SLOW_REQUEST_THRESHOLD_MS=1000
