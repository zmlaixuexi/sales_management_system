# ============================================================
# 销售管理系统 — 环境变量示例
# 复制为 .env 后根据实际环境修改，切勿将 .env 提交到版本控制
# ============================================================

# 应用环境
APP_ENV=development

# 后端端口
BACKEND_PORT=8000

# 前端端口
FRONTEND_PORT=5173

# PostgreSQL 配置（生产环境必须修改密码！）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sales_management

# 数据库连接（Docker 内使用主机名 postgres，本地开发使用 localhost）
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sales_management
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sales_management

# JWT 配置（生产环境必须修改！）
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的前端地址
CORS_ORIGINS=http://localhost:5173

# 日志级别
LOG_LEVEL=INFO

# 日志格式：text（开发）或 json（生产）
LOG_FORMAT=text

# 文件上传配置
UPLOAD_STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
MAX_IMAGE_SIZE_MB=5
MAX_CSV_IMPORT_SIZE_MB=10

# 库存预警阈值
INVENTORY_WARNING_THRESHOLD=10

# API 速率限制（每窗口最大请求数 / 窗口秒数）
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60

# 登录失败速率限制（每 IP 最大失败次数 / 窗口秒数）
LOGIN_FAIL_MAX=10
LOGIN_FAIL_WINDOW_SECONDS=900

# 慢请求阈值（毫秒，超过此值的请求日志升级为 WARNING）
SLOW_REQUEST_THRESHOLD_MS=1000

# 慢 SQL 阈值（毫秒，超过此值的 SQL 记录结构化日志）
SLOW_SQL_THRESHOLD_MS=200

# CSV 导入行数上限
MAX_CSV_IMPORT_ROWS=1000

# 数据库连接池
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=3

# JSON 请求体大小上限（MB，文件上传有独立限制）
MAX_JSON_BODY_MB=1

# HSTS 最大年龄（秒，仅在 HTTPS 生产环境生效）
HSTS_MAX_AGE=31536000
